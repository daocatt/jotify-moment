# PostgreSQL
POSTGRES_USER=postgres
# SECURITY: Use a strong, unique password. Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=jotify_moment
# Host port for PostgreSQL (change if 5432 is already in use)
DB_PORT=5432
# Directory to store database and upload media files
DOCKER_DATA_PATH=./data

# App
# Host port for web app (change if 3000 is already in use)
APP_PORT=3000
# SECURITY: Must match POSTGRES_USER/POSTGRES_PASSWORD above
DATABASE_URL=postgres://postgres:change-me-to-a-strong-password@db:5432/jotify_moment

# Better Auth
# SECURITY: Generate with: openssl rand -hex 32 — never reuse or commit real values
BETTER_AUTH_SECRET=change-me-to-a-secure-random-hex-key
# Must be your public URL when behind a reverse proxy (e.g. https://moment.example.com)
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare Turnstile (optional, leave empty to disable)
# SECURITY: Site key is public; secret must never be exposed to the client
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Google Analytics (optional, leave empty to disable, e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Custom Domains & Caddy Ask Token
# SECURITY: Generate with: openssl rand -hex 16 — this token protects the Caddy ask endpoint
CADDY_ASK_TOKEN=change-me-to-a-secure-random-token
MAIN_HOST=localhost,127.0.0.1
